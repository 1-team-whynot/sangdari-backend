<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.sangdari.domain.auth.mapper.AuthMapper">
    <update
            id="updateRefreshToken"
            parameterType="com.sangdari.domain.user.entities.User"
    >
        UPDATE users
        SET
            refresh_token = #{refreshToken}
            , updated_at = NOW()
        WHERE
            user_id = #{userId}
    </update>
</mapper>