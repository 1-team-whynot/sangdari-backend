<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.sangdari.domain.reservation.mapper.ReservationMenuMapper">
    <insert id="insertAll">
        INSERT INTO reservation_menus (
            reservation_id,
            menu_id
        ) VALUES
        <foreach collection="list" item="reservationMenu" separator=",">
            (
                #{reservationMenu.reservationId},
                #{reservationMenu.menuId}
            )
        </foreach>
    </insert>
</mapper>
